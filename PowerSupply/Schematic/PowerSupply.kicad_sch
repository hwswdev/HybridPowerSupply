	)
	(text "Modes of operation\n\n1. Linear mode dual power supply\nOUT_PLUS  - Power supply \"+\"\nOUT_MID   - Power supplu \"0/GND\"\nOUT_MINUS - Power supply \"-\"\n\n2. Pulse mode power supply\nOUT_PLUS  - Power supply \"+\"\nOUT_MINUS - Power supply \"0/GND\"\n\n3. Signal generator mode\nOUT_MID - Signal generator \"OUT\"\nOUT_GND - Signal generator \"GND\"\n\n\n"
		(exclude_from_sim no)
		(at 779.78 215.9 0)
		(effects
